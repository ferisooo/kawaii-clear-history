{
  "manifest_version": 3,
  "name": "Kawaii Cleaner",
  "version": "1.1.0",
  "description": "Clear your search history & local Google data in one click 🌸",
  "permissions": ["browsingData", "history", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
